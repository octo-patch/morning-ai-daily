---
layout: null
---
<?xml version="1.0" encoding="UTF-8"?>
<feed xmlns="http://www.w3.org/2005/Atom">
  <title>{{ site.title | xml_escape }}</title>
  <subtitle>{{ site.description | xml_escape }}</subtitle>
  <link href="{{ site.url }}{{ site.baseurl }}/feed.xml" rel="self" type="application/atom+xml"/>
  <link href="{{ site.url }}{{ site.baseurl }}/" rel="alternate" type="text/html"/>
  {% assign reports = site.pages | where: "layout", "report" | sort: "date" | reverse %}
  <updated>{{ reports[0].date | date_to_xmlschema }}</updated>
  <id>{{ site.url }}{{ site.baseurl }}/</id>
  <author>
    <name>{{ site.author.name | xml_escape }}</name>
  </author>
  {% for report in reports limit:10 %}
  <entry>
    <title>{{ report.title | xml_escape }}</title>
    <link href="{{ site.url }}{{ report.url | relative_url }}" rel="alternate" type="text/html"/>
    <id>{{ site.url }}{{ report.url | relative_url }}</id>
    <published>{{ report.date | date_to_xmlschema }}</published>
    <updated>{{ report.date | date_to_xmlschema }}</updated>
    <summary type="html">{{ report.summary | xml_escape }}</summary>
    <content type="html">
      {{ report.summary | xml_escape }}
      {% if report.highlights %}
      &lt;ul&gt;
      {% for item in report.highlights %}
        {% if item.score >= 7 %}
        &lt;li&gt;[{{ item.type }}] {{ item.entity | xml_escape }} — {{ item.title | xml_escape }} ({{ item.score }})&lt;/li&gt;
        {% endif %}
      {% endfor %}
      &lt;/ul&gt;
      {% endif %}
    </content>
  </entry>
  {% endfor %}
</feed>
